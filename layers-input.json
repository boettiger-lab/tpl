{
    "catalog": "https://s3-west.nrp-nautilus.io/public-data/stac/catalog.json",
    "titiler_url": "https://titiler.nrp-nautilus.io",
    "mcp_url": "https://duckdb-mcp.nrp-nautilus.io/mcp",
    "auto_approve": true,
    "view": {
        "center": [-96, 38],
        "zoom": 4,
        "globe": true
    },
    "welcome": {
        "message": "Hi! I can help you explore land conservation investment, ballot measure history, carbon data, and more across the United States. Try asking:",
        "examples": [
            "What is the map showing me right now?",
            "Compute the land cover composition of areas protected in the Conservation Almanac nationwide, and which states lead in protecting each cover type?",
            "Which Texas congressional districts recieve the mose federal funding for land conservation? Show on map",
            "Which New Jersey municipalities have passed conservation ballot measures, and how does the pattern of successful measures vary across the state?",
            "Who has funded land conservation in Boulder County, Colorado? show areas on the map."
                   ]
    },
    "links": {
        "github": "https://github.com/boettiger-lab/tpl",
        "carbon": true
    },
    "collections": [
        {
            "collection_id": "landvote",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-tpl/landvote/stac-collection.json",
            "assets": [
                {
                    "id": "landvote-pmtiles",
                    "display_name": "Conservation Ballot Measures",
                    "group": "Conservation Areas",
                    "visible": true,
                    "default_filter": ["all",
                        ["!=", ["get", "jurisdiction"], "State"],
                        [">=", ["get", "year"], 2010]
                    ],
                    "default_style": {
                        "fill-color": ["match", ["get", "status"],
                            "Pass",  "#1B5E20",
                            "Pass*", "#2E7D32",
                            "Fail",  "#C62828",
                            "#9E9E9E"
                        ],
                        "fill-opacity": 0.5
                    },
                    "outline_style": {
                        "line-color": "#424242",
                        "line-width": 0.8
                    },
                    "tooltip_fields": ["municipal", "county", "state", "year", "status", "finance_mechanism", "conservation_funds_approved", "purpose"]
                }
            ]
        },
        {
            "collection_id": "wetlands-global-unified",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-wetlands/stac-collection.json",
            "assets": [
                {
                    "id": "glwd-main-class-cog",
                    "display_name": "Wetland Type (GLWD)",
                    "group": "Wetlands",
                    "visible": false,
                    "legend_type": "categorical"
                }
            ]
        },
        {
            "collection_id": "irrecoverable-carbon",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-carbon/stac-collection.json",
            "assets": [
